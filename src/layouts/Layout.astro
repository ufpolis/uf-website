---
import '@fontsource-variable/eb-garamond';
import '@fontsource/cardo';
import '../styles/global.css';
import { Image } from 'astro:assets';
import ClientRouter from 'astro/components/ClientRouter.astro';
import polisStripped from '../assets/polis_stripped.png';
import site from '../data/site.json';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title       = 'POLIS UF | Pi Lambda Sigma at the University of Florida',
  description = 'POLIS UF (UF POLIS) is the University of Florida chapter of Pi Lambda Sigma, a nonpartisan pre-professional society for public service, law, and policy.',
  ogImage     = '/og-image.png',
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl     = site.siteUrl;
const canonical   = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl  = `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="POLIS UF" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonical} />
    <meta property="og:image"       content={ogImageUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />

    <!-- JSON-LD Organization schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "POLIS UF",
      "alternateName": ["UF POLIS", "POLIS at the University of Florida", "Pi Lambda Sigma at UF"],
      "url": siteUrl,
      "logo": `${siteUrl}/polis_stripped.png`,
      "description": "POLIS UF (UF POLIS) is the University of Florida chapter of Pi Lambda Sigma, a nonpartisan pre-professional government society for students interested in public service, law, policy, and civic leadership.",
      "sameAs": [site.instagram, site.linkedin],
      "parentOrganization": { "@type": "Organization", "name": "Pi Lambda Sigma" },
      "location": {
        "@type": "Place",
        "name": "University of Florida",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Gainesville",
          "addressRegion": "FL",
          "addressCountry": "US"
        }
      }
    })} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <script is:inline>if (!localStorage.getItem('bannerDismissed')) document.documentElement.classList.add('banner-show');</script>
    <ClientRouter />
  </head>

  <body>
    <!-- Skip-to-content link (WCAG 2.2 AA — first focusable element) -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded focus:bg-gold focus:text-dark-blue focus:font-heading focus:text-base"
    >
      Skip to main content
    </a>

    <!-- ============================================================
         STICKY HEADER WRAPPER
         Banner + nav bar share a single sticky container so they
         both transition from transparent to solid dark blue on scroll.
         The head script applies .header-scrolled once the hero exits.
         ============================================================ -->
    <div id="site-header-wrapper" class="sticky top-0 z-50" transition:persist>

    <!-- ============================================================
         FOUNDING CLASS BANNER
         Hidden by default via CSS; head script reveals it when not dismissed.
         ============================================================ -->
    <div
      id="founding-banner"
      class="relative text-white px-4 md:px-8 py-2.5 items-center justify-center gap-2 md:gap-4"
    >
      <p class="font-heading text-sm text-center leading-snug">
        Now recruiting our Founding Class. Applications are open.
        <a
          href={site.applyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="font-semibold underline hover:no-underline ml-1"
        >Apply Now<span class="sr-only"> (opens in new tab)</span></a>
      </p>
      <button
        id="dismiss-banner"
        type="button"
        aria-label="Dismiss recruitment banner"
        class="absolute right-3 top-1/2 -translate-y-1/2 flex items-center justify-center w-7 h-7 rounded hover:bg-white/10 transition-colors"
      >
        <svg aria-hidden="true" width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="1" y1="1" x2="11" y2="11"/>
          <line x1="11" y1="1" x2="1" y2="11"/>
        </svg>
      </button>
    </div>

    <!-- ============================================================
         SITE HEADER
         Desktop (≥768px): logo | nav links | social icons + email
         Mobile  (<768px): logo | social icons + email + hamburger
         ============================================================ -->
    <header>
      <nav
        aria-label="Main navigation"
        class="max-w-7xl mx-auto grid grid-cols-[1fr_auto_1fr] items-center px-4 md:px-6 h-14 md:h-16"
      >

        <!-- LEFT: Logo (desktop) + hamburger (mobile) -->
        <div class="flex items-center gap-2">

          <!-- Logo -->
          <a href="/" aria-label="POLIS — home" id="header-logo-link">
            <Image
              src={polisStripped}
              alt=""
              width={88}
              height={88}
              class="h-9 md:h-11 w-auto"
              loading="eager"
            />
          </a>

          <!-- Hamburger button (mobile only) -->
          <button
            id="hamburger-btn"
            type="button"
            aria-expanded="false"
            aria-controls="mobile-menu"
            aria-label="Open menu"
            class="md:hidden flex items-center justify-center w-11 h-11 text-white/80 hover:text-gold transition-colors"
          >
            <svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <line x1="2" y1="5" x2="20" y2="5"/>
              <line x1="2" y1="11" x2="20" y2="11"/>
              <line x1="2" y1="17" x2="20" y2="17"/>
            </svg>
          </button>

        </div>

        <!-- CENTER: Nav links (desktop only — auto column between two equal 1fr sides = true center) -->
        <ul class="hidden md:flex items-center gap-1 list-none m-0 p-0" role="list">

          <li>
            <a
              href="/"
              aria-current={currentPath === '/' ? 'page' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors relative nav-link-underline whitespace-nowrap',
                currentPath === '/' ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >Home</a>
          </li>

          <li>
            <a
              href="/network"
              aria-current={currentPath.startsWith('/network') ? 'page' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors relative nav-link-underline whitespace-nowrap',
                currentPath.startsWith('/network') ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >Network</a>
          </li>

          <!-- Members dropdown: click-primary, keyboard-accessible -->
          <li class="relative">
            <button
              id="members-btn"
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              data-active={currentPath.startsWith('/members') ? 'true' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors flex items-center gap-1 cursor-pointer relative nav-link-underline whitespace-nowrap',
                currentPath.startsWith('/members') ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >
              Members
              <svg
                id="members-chevron"
                aria-hidden="true"
                class="w-3 h-3 opacity-60 transition-transform duration-200"
                viewBox="0 0 12 12"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <polyline points="2 4 6 8 10 4" />
              </svg>
            </button>

            <ul
              id="members-panel"
              role="menu"
              class="dropdown-panel absolute top-full left-0 mt-1 w-52 bg-dark-blue border border-white/10 rounded-sm shadow-lg list-none p-1"
            >
              <li role="none">
                <a
                  href="/members/executive-board"
                  role="menuitem"
                  aria-current={currentPath === '/members/executive-board' ? 'page' : undefined}
                  class="block font-heading text-sm text-white/80 hover:text-white hover:bg-white/10 px-4 py-2 rounded-sm transition-colors"
                >Executive Board</a>
              </li>
              <li role="none">
                <a
                  href="/members/active-members"
                  role="menuitem"
                  aria-current={currentPath === '/members/active-members' ? 'page' : undefined}
                  class="block font-heading text-sm text-white/80 hover:text-white hover:bg-white/10 px-4 py-2 rounded-sm transition-colors"
                >Active Members</a>
              </li>
              <li role="none">
                <a
                  href="/members/alumni"
                  role="menuitem"
                  aria-current={currentPath === '/members/alumni' ? 'page' : undefined}
                  class="block font-heading text-sm text-white/80 hover:text-white hover:bg-white/10 px-4 py-2 rounded-sm transition-colors"
                >Alumni</a>
              </li>
            </ul>
          </li>

          <li>
            <a
              href="/programming"
              aria-current={currentPath.startsWith('/programming') ? 'page' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors relative nav-link-underline whitespace-nowrap',
                currentPath.startsWith('/programming') ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >Programming</a>
          </li>

          <li>
            <a
              href="/philanthropy"
              aria-current={currentPath.startsWith('/philanthropy') ? 'page' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors relative nav-link-underline whitespace-nowrap',
                currentPath.startsWith('/philanthropy') ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >Philanthropy</a>
          </li>

          <li>
            <a
              href="/join"
              aria-current={currentPath.startsWith('/join') ? 'page' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors relative nav-link-underline whitespace-nowrap',
                currentPath.startsWith('/join') ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >Join</a>
          </li>

          <li>
            <a
              href="/contact"
              aria-current={currentPath.startsWith('/contact') ? 'page' : undefined}
              class:list={[
                'font-heading text-sm px-3 md:px-2 lg:px-3 py-2 rounded-sm transition-colors relative nav-link-underline whitespace-nowrap',
                currentPath.startsWith('/contact') ? 'text-gold' : 'text-white/80 hover:text-white',
              ]}
            >Contact</a>
          </li>

        </ul>

        <!-- RIGHT: Social icons — col-start-3 pins them to the third column so
             they stay on the right even when the center nav is hidden on mobile. -->
        <div class="col-start-3 flex items-center justify-end">

          <a
            href={site.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-8 h-8 md:w-9 md:h-9 lg:w-10 lg:h-10 rounded-sm text-white/60 hover:text-gold transition-colors"
            aria-label="POLIS UF on Instagram (opens in new tab)"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
            <span class="sr-only">Instagram (opens in new tab)</span>
          </a>

          <a
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-8 h-8 md:w-9 md:h-9 lg:w-10 lg:h-10 rounded-sm text-white/60 hover:text-gold transition-colors"
            aria-label="POLIS UF on LinkedIn (opens in new tab)"
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="sr-only">LinkedIn (opens in new tab)</span>
          </a>

          <a
            href={`mailto:${site.email}`}
            class="flex md:hidden lg:flex items-center justify-center w-8 h-8 lg:w-10 lg:h-10 rounded-sm text-white/60 hover:text-gold transition-colors"
            aria-label={`Email POLIS UF at ${site.email}`}
          >
            <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </a>

        </div>

      </nav>
    </header>

    </div>{/* end #site-header-wrapper */}

    <!-- ============================================================
         MOBILE OVERLAY
         Full-screen, slides in from the right.
         aria-hidden + translate-x-full while closed.
         JS toggles both; focus is trapped while open.
         ============================================================ -->
    <div
      id="mobile-menu"
      role="dialog"
      aria-modal="true"
      aria-label="Navigation menu"
      aria-hidden="true"
      class="fixed inset-0 z-[60] bg-dark-blue flex flex-col overflow-y-auto
             translate-x-full transition-transform duration-300 ease-in-out"
    >
      <!-- Close button -->
      <div class="flex justify-end px-4 pt-3 shrink-0">
        <button
          id="close-menu-btn"
          type="button"
          aria-label="Close menu"
          class="flex items-center justify-center w-11 h-11 text-white/80 hover:text-gold transition-colors"
        >
          <svg aria-hidden="true" width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <line x1="3" y1="3" x2="19" y2="19"/>
            <line x1="19" y1="3" x2="3" y2="19"/>
          </svg>
        </button>
      </div>

      <!-- Mobile nav links -->
      <nav aria-label="Mobile navigation" class="flex flex-col px-6 pb-12 mt-2">

        <a
          href="/"
          aria-current={currentPath === '/' ? 'page' : undefined}
          class:list={[
            'font-heading text-xl py-4 border-b border-white/10 transition-colors',
            currentPath === '/' ? 'text-gold' : 'text-white hover:text-gold',
          ]}
        >Home</a>

        <a
          href="/network"
          aria-current={currentPath.startsWith('/network') ? 'page' : undefined}
          class:list={[
            'font-heading text-xl py-4 border-b border-white/10 transition-colors',
            currentPath.startsWith('/network') ? 'text-gold' : 'text-white hover:text-gold',
          ]}
        >Network</a>

        <!-- Members accordion using <details>/<summary> — no JS needed -->
        <details
          class="border-b border-white/10"
          open={currentPath.startsWith('/members') || undefined}
        >
          <summary
            class:list={[
              'font-heading text-xl py-4 cursor-pointer list-none flex justify-between items-center transition-colors',
              currentPath.startsWith('/members') ? 'text-gold' : 'text-white hover:text-gold',
            ]}
          >
            Members
            <svg
              aria-hidden="true"
              class="details-chevron w-4 h-4 shrink-0 opacity-60 transition-transform duration-200"
              viewBox="0 0 16 16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="3 6 8 11 13 6"/>
            </svg>
          </summary>
          <div class="flex flex-col pl-4 pb-3 pt-1">
            <a
              href="/members/executive-board"
              aria-current={currentPath === '/members/executive-board' ? 'page' : undefined}
              class:list={[
                'font-heading text-base py-3 border-b border-white/5 transition-colors',
                currentPath === '/members/executive-board' ? 'text-gold' : 'text-white/80 hover:text-gold',
              ]}
            >Executive Board</a>
            <a
              href="/members/active-members"
              aria-current={currentPath === '/members/active-members' ? 'page' : undefined}
              class:list={[
                'font-heading text-base py-3 border-b border-white/5 transition-colors',
                currentPath === '/members/active-members' ? 'text-gold' : 'text-white/80 hover:text-gold',
              ]}
            >Active Members</a>
            <a
              href="/members/alumni"
              aria-current={currentPath === '/members/alumni' ? 'page' : undefined}
              class:list={[
                'font-heading text-base py-3 transition-colors',
                currentPath === '/members/alumni' ? 'text-gold' : 'text-white/80 hover:text-gold',
              ]}
            >Alumni</a>
          </div>
        </details>

        <a
          href="/programming"
          aria-current={currentPath.startsWith('/programming') ? 'page' : undefined}
          class:list={[
            'font-heading text-xl py-4 border-b border-white/10 transition-colors',
            currentPath.startsWith('/programming') ? 'text-gold' : 'text-white hover:text-gold',
          ]}
        >Programming</a>

        <a
          href="/philanthropy"
          aria-current={currentPath.startsWith('/philanthropy') ? 'page' : undefined}
          class:list={[
            'font-heading text-xl py-4 border-b border-white/10 transition-colors',
            currentPath.startsWith('/philanthropy') ? 'text-gold' : 'text-white hover:text-gold',
          ]}
        >Philanthropy</a>

        <a
          href="/join"
          aria-current={currentPath.startsWith('/join') ? 'page' : undefined}
          class:list={[
            'font-heading text-xl py-4 border-b border-white/10 transition-colors',
            currentPath.startsWith('/join') ? 'text-gold' : 'text-white hover:text-gold',
          ]}
        >Join</a>

        <a
          href="/contact"
          aria-current={currentPath.startsWith('/contact') ? 'page' : undefined}
          class:list={[
            'font-heading text-xl py-4 transition-colors',
            currentPath.startsWith('/contact') ? 'text-gold' : 'text-white hover:text-gold',
          ]}
        >Contact</a>

      </nav>
    </div>

    <slot />

    <!-- ============================================================
         SHARED FOOTER
         Values imported from src/data/site.json.
         To update a link or email, edit that file — not this one.
         ============================================================ -->
    <footer class="bg-dark-blue text-white">
      <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">

        <!-- Brand column -->
        <div class="flex flex-col gap-4">
          <a href="/" aria-label="POLIS UF — home" class="w-fit">
            <Image
              src={polisStripped}
              alt=""
              width={104}
              height={104}
              class="h-13 w-auto"
              loading="lazy"
            />
          </a>
          <div>
            <p class="font-heading text-white text-lg leading-snug">Pi Lambda Sigma</p>
            <p class="font-heading text-white/60 text-sm">University of Florida</p>
          </div>
          <p class="font-heading text-white/50 text-sm leading-relaxed max-w-xs">
            A nonpartisan pre-professional government society for students passionate about
            public service, law, policy, and civic leadership.
          </p>
        </div>

        <!-- Quick links column -->
        <div>
          <h2 class="font-heading text-gold text-sm uppercase tracking-widest mb-5">Quick Links</h2>
          <ul class="grid grid-cols-2 gap-x-4 gap-y-2 list-none p-0 m-0">
            <li><a href="/" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Home</a></li>
            <li><a href="/network" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Network</a></li>
            <li><a href="/members/executive-board" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Executive Board</a></li>
            <li><a href="/members/active-members" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Active Members</a></li>
            <li><a href="/members/alumni" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Alumni</a></li>
            <li><a href="/programming" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Programming</a></li>
            <li><a href="/philanthropy" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Philanthropy</a></li>
            <li><a href="/join" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Join</a></li>
            <li><a href="/contact" class="font-heading text-white/70 hover:text-white text-sm transition-colors">Contact</a></li>
          </ul>
        </div>

        <!-- Connect column -->
        <div>
          <h2 class="font-heading text-gold text-sm uppercase tracking-widest mb-5">Connect</h2>
          <div class="flex flex-col gap-3">
            <a
              href={site.instagram}
              target="_blank"
              rel="noopener noreferrer"
              class="font-heading text-white/70 hover:text-white text-sm transition-colors flex items-center gap-2"
            >
              Instagram
              <span class="text-white/30">— {site.instagramHandle}</span>
              <span class="sr-only">(opens in new tab)</span>
            </a>
            <a
              href={site.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="font-heading text-white/70 hover:text-white text-sm transition-colors"
            >
              LinkedIn
              <span class="sr-only">(opens in new tab)</span>
            </a>
            <a
              href={`mailto:${site.email}`}
              class="font-heading text-white/70 hover:text-white text-sm transition-colors"
            >
              {site.email}
            </a>
            <a
              href={site.applyUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-magnetic
              class="mt-3 inline-block bg-gold text-dark-blue font-heading font-semibold text-sm px-5 py-2 rounded-sm hover:brightness-110 transition w-fit"
            >
              Apply Now
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </div>
        </div>

      </div>

      <!-- Bottom bar -->
      <div class="border-t border-white/10">
        <p class="max-w-7xl mx-auto px-6 py-5 font-heading text-white/40 text-xs text-center">
          &copy; 2025 Pi Lambda Sigma at the University of Florida. All rights reserved.
        </p>
      </div>
    </footer>

    <script>
      // ================================================================
      // ONE-TIME SETUP — runs once per page lifetime (module script)
      // ================================================================

      // Abort controllers for scroll listeners that must be torn down on navigation
      let _sealAbort: AbortController | null = null;
      let _cueAbort:  AbortController | null = null;

      // Close mobile overlay + restore header logo before View Transitions page swap
      document.addEventListener('astro:before-preparation', () => {
        // Restore logo + hamburger visibility on navigation away
        const _logoEl = document.getElementById('header-logo-link') as HTMLElement | null;
        if (_logoEl) { _logoEl.style.opacity = ''; _logoEl.classList.remove('home-page-logo-hidden'); }
        const _hambEl = document.getElementById('hamburger-btn') as HTMLElement | null;
        if (_hambEl) _hambEl.style.opacity = '';

        const overlay = document.getElementById('mobile-menu');
        if (overlay?.getAttribute('aria-hidden') === 'false') {
          overlay.classList.add('translate-x-full');
          overlay.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          const hamburger = document.getElementById('hamburger-btn');
          if (hamburger) {
            hamburger.setAttribute('aria-expanded', 'false');
            hamburger.setAttribute('aria-label', 'Open menu');
          }
        }
      });

      // Header bg — single scroll listener referencing DOM dynamically
      function updateHeaderBg() {
        document.getElementById('site-header-wrapper')
          ?.classList.toggle('header-scrolled', window.scrollY > 48);
      }
      window.addEventListener('scroll', updateHeaderBg, { passive: true });

      // Close overlay on resize to desktop without moving focus
      window.addEventListener('resize', () => {
        const overlay = document.getElementById('mobile-menu');
        if (window.innerWidth >= 768 && overlay?.getAttribute('aria-hidden') === 'false') {
          overlay.classList.add('translate-x-full');
          overlay.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          const hamburger = document.getElementById('hamburger-btn');
          if (hamburger) {
            hamburger.setAttribute('aria-expanded', 'false');
            hamburger.setAttribute('aria-label', 'Open menu');
          }
        }
      }, { passive: true });

      // ================================================================
      // SEAL FADE — hero seal fades out on scroll, header logo fades in
      // ================================================================

      function initSealMigration() {
        _sealAbort?.abort();
        _sealAbort = null;

        const heroSeal   = document.getElementById('hero-seal') as HTMLElement | null;
        const headerLogo = document.getElementById('header-logo-link') as HTMLElement | null;
        const hamburger  = document.getElementById('hamburger-btn') as HTMLElement | null;
        const hero       = document.querySelector<HTMLElement>('.hero-spotlight');

        if (!heroSeal || !headerLogo || !hero) {
          if (headerLogo) { headerLogo.style.opacity = ''; headerLogo.classList.remove('home-page-logo-hidden'); }
          if (hamburger)    hamburger.style.opacity = '';
          return;
        }

        // On mobile (< 768px) always show the logo and hamburger immediately.
        // On desktop, fade them in as the hero seal scrolls away.
        const isMobile = window.innerWidth < 768;

        headerLogo.style.opacity = isMobile ? '1' : '0';
        if (hamburger) hamburger.style.opacity = isMobile ? '1' : '0';

        const threshold = hero.offsetHeight * 0.5;
        const noMotion  = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        _sealAbort = new AbortController();

        function update() {
          const p = Math.min(1, Math.max(0, window.scrollY / threshold));
          heroSeal.style.opacity = noMotion ? (p < 0.5 ? '1' : '0') : String(1 - p);
          if (isMobile) return;
          if (noMotion) {
            headerLogo.style.opacity = p < 0.5 ? '0' : '1';
            if (hamburger) hamburger.style.opacity = p < 0.5 ? '0' : '1';
            return;
          }
          headerLogo.style.opacity = String(p);
          if (hamburger) hamburger.style.opacity = String(p);
        }

        update(); // correct state immediately on load (handles scrollY > 0)

        let rafId: number;
        window.addEventListener('scroll', () => {
          cancelAnimationFrame(rafId);
          rafId = requestAnimationFrame(update);
        }, { passive: true, signal: _sealAbort.signal });
      }

      // ================================================================
      // PER-NAVIGATION INIT — fires on initial load + every SPA navigation
      // ================================================================

      document.addEventListener('astro:page-load', () => {
        updateHeaderBg();

        // ----------------------------------------------------------------
        // Hero seal migration + scroll cue (home page only)
        // ----------------------------------------------------------------
        initSealMigration();

        _cueAbort?.abort();
        _cueAbort = null;
        const scrollCue = document.getElementById('scroll-cue');
        if (scrollCue) {
          _cueAbort = new AbortController();
          // Reset cue visibility (may have been hidden if user was previously scrolled)
          scrollCue.classList.remove('is-hidden');
          window.addEventListener('scroll', () => {
            scrollCue.classList.toggle('is-hidden', window.scrollY > 60);
          }, { passive: true, signal: _cueAbort.signal });
        }

        // ----------------------------------------------------------------
        // Scroll fade-up entrance animation (re-observe on each navigation)
        // ----------------------------------------------------------------
        const fadeObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                fadeObs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.06 }
        );
        document.querySelectorAll('.fade-up').forEach((el) => fadeObs.observe(el));

        // ----------------------------------------------------------------
        // Animated section dividers (Effect 11)
        // ----------------------------------------------------------------
        const divObs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                divObs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.3 }
        );
        document.querySelectorAll('.section-divider').forEach((el) => divObs.observe(el));

        // ----------------------------------------------------------------
        // Founding Class banner dismiss (persistent element — attach once)
        // ----------------------------------------------------------------
        const dismissBtn = document.getElementById('dismiss-banner') as HTMLElement | null;
        if (dismissBtn && !dismissBtn.dataset.listenerAttached) {
          dismissBtn.dataset.listenerAttached = 'true';
          dismissBtn.addEventListener('click', () => {
            document.getElementById('founding-banner')?.remove();
            localStorage.setItem('bannerDismissed', '1');
          });
        }

        // ----------------------------------------------------------------
        // Mobile menu
        // Hamburger persists (transition:persist on header wrapper) — attach once.
        // Close button and overlay are re-rendered on navigation — re-attach each time.
        // ----------------------------------------------------------------
        const hamburger = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
        const overlay   = document.getElementById('mobile-menu') as HTMLElement | null;
        const closeBtn  = document.getElementById('close-menu-btn') as HTMLButtonElement | null;

        if (hamburger && !hamburger.dataset.listenerAttached) {
          hamburger.dataset.listenerAttached = 'true';
          hamburger.addEventListener('click', openMenu);
        }

        closeBtn?.addEventListener('click', closeMenu);
        overlay?.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Escape') { closeMenu(); return; }
          if (e.key !== 'Tab') return;
          const focusable = [...(overlay?.querySelectorAll<HTMLElement>('a[href], button, summary') ?? [])];
          const first = focusable[0];
          const last  = focusable[focusable.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault(); last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault(); first.focus();
          }
        });

        // ----------------------------------------------------------------
        // Desktop Members dropdown (persistent — attach once)
        // ----------------------------------------------------------------
        const membersBtn     = document.getElementById('members-btn')     as HTMLButtonElement | null;
        const membersPanel   = document.getElementById('members-panel')   as HTMLElement | null;
        const membersChevron = document.getElementById('members-chevron') as HTMLElement | null;

        if (membersBtn && membersPanel && !membersBtn.dataset.listenerAttached) {
          membersBtn.dataset.listenerAttached = 'true';
          const menuItems = [...membersPanel.querySelectorAll<HTMLElement>('[role="menuitem"]')];
          const isPanelOpen = () => membersPanel.classList.contains('is-open');

          const openDropdown = () => {
            membersPanel!.classList.add('is-open');
            membersBtn!.setAttribute('aria-expanded', 'true');
            if (membersChevron) membersChevron.style.transform = 'rotate(180deg)';
          };
          const closeDropdown = () => {
            membersPanel!.classList.remove('is-open');
            membersBtn!.setAttribute('aria-expanded', 'false');
            if (membersChevron) membersChevron.style.transform = '';
          };

          membersBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            isPanelOpen() ? closeDropdown() : openDropdown();
          });
          membersBtn.addEventListener('keydown', (e: KeyboardEvent) => {
            if (e.key === 'ArrowDown') { e.preventDefault(); openDropdown(); menuItems[0]?.focus(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); openDropdown(); menuItems[menuItems.length - 1]?.focus(); }
            else if (e.key === 'Escape') { closeDropdown(); }
          });
          membersPanel.addEventListener('keydown', (e: KeyboardEvent) => {
            const idx = menuItems.indexOf(document.activeElement as HTMLElement);
            if (e.key === 'ArrowDown') { e.preventDefault(); menuItems[(idx + 1) % menuItems.length]?.focus(); }
            else if (e.key === 'ArrowUp') { e.preventDefault(); menuItems[(idx - 1 + menuItems.length) % menuItems.length]?.focus(); }
            else if (e.key === 'Escape') { closeDropdown(); membersBtn!.focus(); }
            else if (e.key === 'Tab') { closeDropdown(); }
          });
          document.addEventListener('click', (e) => {
            if (isPanelOpen() && !membersBtn!.contains(e.target as Node) && !membersPanel!.contains(e.target as Node)) {
              closeDropdown();
            }
          });
        }

        // ----------------------------------------------------------------
        // Flip cards: one flipped per grid, aria-pressed + label updated.
        // Both faces live inside the <button>; is-flipped class on the
        // button drives the CSS 3D rotation via .flip-inner.
        // ----------------------------------------------------------------
        const HINT_MORE = 'activate to read more';
        const HINT_BACK = 'activate to flip back';

        function unflipCard(card: HTMLElement) {
          card.classList.remove('is-flipped');
          card.setAttribute('aria-pressed', 'false');
          card.setAttribute('aria-label',
            (card.getAttribute('aria-label') ?? '').replace(HINT_BACK, HINT_MORE));
          const front = card.querySelector<HTMLElement>('.flip-front');
          const back  = card.querySelector<HTMLElement>('.flip-back');
          front?.removeAttribute('aria-hidden');
          front?.removeAttribute('inert');
          back?.setAttribute('aria-hidden', 'true');
          back?.setAttribute('inert', '');
        }

        function flipCard(card: HTMLElement) {
          card.classList.add('is-flipped');
          card.setAttribute('aria-pressed', 'true');
          card.setAttribute('aria-label',
            (card.getAttribute('aria-label') ?? '').replace(HINT_MORE, HINT_BACK));
          const front = card.querySelector<HTMLElement>('.flip-front');
          const back  = card.querySelector<HTMLElement>('.flip-back');
          front?.setAttribute('aria-hidden', 'true');
          front?.setAttribute('inert', '');
          back?.removeAttribute('aria-hidden');
          back?.removeAttribute('inert');
        }

        document.querySelectorAll('[data-icon-grid]').forEach((grid) => {
          const cards = [...grid.querySelectorAll<HTMLElement>('.flip-card')];
          cards.forEach((card) => {
            card.addEventListener('click', () => {
              const isFlipped = card.classList.contains('is-flipped');
              const currentFlipped = cards.find((c) => c.classList.contains('is-flipped'));
              if (currentFlipped) unflipCard(currentFlipped);
              if (!isFlipped) flipCard(card);
            });
          });
        });

        // Set each flip-card-wrapper's min-height to whichever face is taller.
        // Both faces are position:absolute so without this the card collapses.
        document.querySelectorAll<HTMLElement>('.flip-card-wrapper').forEach((wrapper) => {
          const card  = wrapper.querySelector<HTMLElement>('.flip-card');
          const front = wrapper.querySelector<HTMLElement>('.flip-front');
          const back  = wrapper.querySelector<HTMLElement>('.flip-back');
          if (!card || !front || !back) return;

          // Temporarily bring back face into normal flow for measurement
          back.style.position = 'static';
          back.style.transform = 'none';
          back.style.visibility = 'hidden';
          const h = Math.max(front.scrollHeight, back.scrollHeight);
          back.style.position = '';
          back.style.transform = '';
          back.style.visibility = '';

          wrapper.style.minHeight = h + 'px';
        });

        // ----------------------------------------------------------------
        // Magnetic hover on [data-magnetic] elements (Effect 1)
        // CSS handles the spring-back transition via :not(:hover).
        // JS only tracks cursor and applies the transform directly.
        // ----------------------------------------------------------------
        const noMotion    = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const finePointer = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        if (!noMotion && finePointer) {
          document.querySelectorAll<HTMLElement>('[data-magnetic]').forEach((el) => {
            if (el.dataset.magneticAttached) return;
            el.dataset.magneticAttached = 'true';
            let rafId: number;
            el.addEventListener('mousemove', (e) => {
              cancelAnimationFrame(rafId);
              rafId = requestAnimationFrame(() => {
                const r = el.getBoundingClientRect();
                const dx = Math.max(-5, Math.min(5, ((e as MouseEvent).clientX - r.left - r.width / 2) * 0.3));
                const dy = Math.max(-5, Math.min(5, ((e as MouseEvent).clientY - r.top - r.height / 2) * 0.3));
                el.style.transform = `translate(${dx}px, ${dy}px)`;
              });
            });
            el.addEventListener('mouseleave', () => {
              cancelAnimationFrame(rafId);
              el.style.transform = '';
            });
          });
        }
      });

      // ================================================================
      // MOBILE MENU HELPERS — defined at module level, referenced by
      // both astro:page-load handlers and event listeners above.
      // Function declarations are hoisted, so usage above is safe.
      // ================================================================

      function openMenu() {
        const overlay   = document.getElementById('mobile-menu') as HTMLElement | null;
        const hamburger = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
        if (!overlay || !hamburger) return;
        overlay.classList.remove('translate-x-full');
        overlay.setAttribute('aria-hidden', 'false');
        hamburger.setAttribute('aria-expanded', 'true');
        hamburger.setAttribute('aria-label', 'Close menu');
        document.body.style.overflow = 'hidden';
        (document.getElementById('close-menu-btn') as HTMLButtonElement | null)?.focus();
      }

      function closeMenu() {
        const overlay   = document.getElementById('mobile-menu') as HTMLElement | null;
        const hamburger = document.getElementById('hamburger-btn') as HTMLButtonElement | null;
        if (!overlay || !hamburger) return;
        overlay.classList.add('translate-x-full');
        overlay.setAttribute('aria-hidden', 'true');
        hamburger.setAttribute('aria-expanded', 'false');
        hamburger.setAttribute('aria-label', 'Open menu');
        document.body.style.overflow = '';
        hamburger.focus();
      }
    </script>

  </body>
</html>
