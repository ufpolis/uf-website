---
import Layout from '../layouts/Layout.astro';

// To add or remove internship entries, edit src/data/internships.json — not this file.
import networkData from '../data/internships.json';

const { houseEntries, entries: internshipEntries } = networkData;

// House logo served from public/ (SVG, no Astro processing needed)
const HOUSE_LOGO = '/network-logos/www_house.svg';
---

<Layout
  title="Where Our Members Work | POLIS UF"
  description="POLIS UF (UF POLIS) members intern and work across public service, law, government, and policy. Explore our growing Pi Lambda Sigma network at UF."
>
  <main id="main-content">

    <!-- Page header -->
    <section class="bg-dark-blue py-20 md:py-28 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-heading text-gold text-sm uppercase tracking-widest mb-4">Where We Work</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl leading-tight mb-6">
          Our Network
        </h1>
        <p class="font-heading text-white/80 text-xl max-w-2xl mx-auto leading-relaxed">
          POLIS members and alumni work and intern across public service, law, government,
          policy, and civic leadership. This page will grow as our Founding Class enters the field.
        </p>
      </div>
    </section>


    <!-- Network grid -->
    <section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-5xl mx-auto">

        <div class="section-divider" aria-hidden="true"></div>
        <h2 class="font-heading text-dark-blue text-3xl md:text-4xl text-center mb-14 fade-up">
          Organizations and Institutions
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

          <!-- House of Representatives entries (always first) -->
          {houseEntries.map((entry: any, i: number) => (
            <div
              class="fade-up bg-white border border-gray rounded-sm p-5 flex flex-col gap-4
                     hover:border-gold hover:shadow-lg transition-all duration-300"
              style={`transition-delay: ${i * 60}ms`}
            >
              <p class="font-heading text-dark-blue text-sm leading-snug">{entry.title}</p>
              <div class="flex-1 flex items-center justify-center min-h-[6rem]">
                <img
                  src={HOUSE_LOGO}
                  alt="U.S. House of Representatives"
                  class="max-w-full max-h-24 w-auto h-auto"
                  loading="lazy"
                />
              </div>
            </div>
          ))}

          <!-- Internship logo entries from internships.json -->
          {internshipEntries.map((card: any, i: number) => (
            <div
              class="fade-up bg-white border border-gray rounded-sm p-5 flex flex-col gap-4
                     hover:border-gold hover:shadow-lg transition-all duration-300"
              style={`transition-delay: ${(i + houseEntries.length) * 60}ms`}
            >
              <p class="font-heading text-dark-blue text-sm leading-snug">{card.title}</p>
              <div class="flex-1 flex items-center justify-center min-h-[6rem]">
                <img
                  src={card.logo}
                  alt={card.alt}
                  class="max-w-full max-h-24 w-auto h-auto"
                  loading="lazy"
                />
              </div>
            </div>
          ))}

        </div>

        <p class="font-heading text-dark-blue/50 text-sm text-center mt-14 fade-up">
          Logos and organizations will be added as members and alumni share their placements.
        </p>

      </div>
    </section>

  </main>
</Layout>
