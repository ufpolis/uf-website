---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// ----------------------------------------------------------------
// INTERNSHIP LOGOS — auto-loaded from src/assets/internships/
//
// To add a new entry: drop a .png or .jpg file into that folder.
// The filename becomes the card title:
//   - Hyphens become spaces
//   - A trailing -1, -2, -3 … suffix is stripped (multiple logos
//     for the same category each get their own card under the same
//     title, e.g. Legal-1.png, Legal-2.jpg, Legal-3.jpg → "Legal")
//   - "and" stays lowercase because filenames already use it lowercase
// ----------------------------------------------------------------
const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/internships/*.{png,jpg,jpeg,PNG,JPG,JPEG}',
  { eager: true }
);

function filenameToTitle(path: string): string {
  const stem = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
  return stem.replace(/-\d+$/, '').replace(/-/g, ' ');
}

const internshipCards = Object.entries(logoModules)
  .map(([path, mod]) => ({ title: filenameToTitle(path), image: mod.default }))
  .sort((a, b) => a.title.localeCompare(b.title));

// House of Representatives entries — always first, share the House logo
const HOUSE_LOGO = '/network-logos/www_house.svg';
const houseEntries = [
  { title: 'Office of Rep. Jill Tokuda (HI-02)' },
  { title: 'Office of Rep. Kathy Castor (FL-14)' },
  { title: 'Office of Rep. Anna Paulina Luna (FL-13)' },
];

const totalCards = houseEntries.length + internshipCards.length;
---

<Layout
  title="Network — POLIS UF"
  description="A growing network of POLIS UF members working across public service, law, government, and policy."
>
  <main id="main-content">

    <!-- Page header -->
    <section class="bg-dark-blue py-20 md:py-28 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-heading text-gold text-sm uppercase tracking-widest mb-4">Where We Work</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl leading-tight mb-6">
          Our Network
        </h1>
        <p class="font-heading text-white/80 text-xl max-w-2xl mx-auto leading-relaxed">
          POLIS UF members and alumni work and intern across public service, law, government,
          policy, and civic leadership. This page will grow as our Founding Class enters the field.
        </p>
      </div>
    </section>


    <!-- Network grid -->
    <section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-5xl mx-auto">

        <h2 class="font-heading text-dark-blue text-3xl md:text-4xl text-center mb-14 fade-up">
          Organizations and Institutions
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

          <!-- House of Representatives entries (always first) -->
          {houseEntries.map((entry, i) => (
            <div
              class="fade-up bg-white border border-gray rounded-sm p-5 flex flex-col gap-4
                     hover:border-gold hover:shadow-lg transition-all duration-300"
              style={`transition-delay: ${i * 60}ms`}
            >
              <p class="font-heading text-dark-blue text-sm leading-snug">{entry.title}</p>
              <div class="flex-1 flex items-center justify-center min-h-[6rem]">
                <img
                  src={HOUSE_LOGO}
                  alt="U.S. House of Representatives"
                  class="max-w-full max-h-24 w-auto h-auto"
                  loading="lazy"
                />
              </div>
            </div>
          ))}

          <!-- Internship logos (auto-loaded from src/assets/internships/) -->
          {internshipCards.map((card, i) => (
            <div
              class="fade-up bg-white border border-gray rounded-sm p-5 flex flex-col gap-4
                     hover:border-gold hover:shadow-lg transition-all duration-300"
              style={`transition-delay: ${(i + houseEntries.length) * 60}ms`}
            >
              <p class="font-heading text-dark-blue text-sm leading-snug">{card.title}</p>
              <div class="flex-1 flex items-center justify-center min-h-[6rem]">
                <Image
                  src={card.image}
                  alt=""
                  width={280}
                  class="max-w-full max-h-24 w-auto h-auto"
                  loading="lazy"
                />
              </div>
            </div>
          ))}

        </div>

        <p class="font-heading text-dark-blue/50 text-sm text-center mt-14 fade-up">
          Logos and organizations will be added as members and alumni share their placements.
        </p>

      </div>
    </section>

  </main>
</Layout>
