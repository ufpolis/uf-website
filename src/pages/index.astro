---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import capitalSunset from '../assets/capital_sunset.jpg';
import landingImage from '../assets/landing_image.jpg';
import ufImage from '../assets/uf_image.jpg';
import senatePainting from '../assets/senate_painting.jpg';
import polisMain from '../assets/polis_stripped.png';
import site from '../data/site.json';
import home from '../data/home.json';
import { toHtml, toHtmlLede, toHtmlLedeFirstPara, toHtmlAfterFirstPara } from '../utils/markdown';
import networkData from '../data/internships.json';

const HOUSE_LOGO = '/network-logos/www_house.svg';
const allLogos: { src: string; alt: string; title: string }[] = [
  ...networkData.houseEntries.map((e: any) => ({
    src:   HOUSE_LOGO,
    alt:   'U.S. House of Representatives',
    title: e.title,
  })),
  ...(networkData.entries as any[]).map((e) => ({
    src:   e.logo,
    alt:   e.alt || e.title,
    title: e.title,
  })),
];

// Icons for the three mission goal flip cards (indexed to match home.mission.goals order)
const goalIcons = [
  // Card 1 — Public Service & Ethical Leadership: star
  `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  // Card 2 — Inclusive Governance & Accessibility: globe
  `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
  // Card 3 — Professional Development with Public Purpose: mortarboard
  `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
];
---

<Layout title="POLIS UF — Pi Lambda Sigma at the University of Florida">
  <main id="main-content">

    <!-- ============================================================
         HERO
         ============================================================ -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden hero-spotlight">

      <div class="absolute inset-0 z-0">
        <Image
          src={capitalSunset}
          alt=""
          class="w-full h-full object-cover"
          width={1600}
          height={900}
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-dark-blue/65"></div>
      </div>

      <div class="relative z-10 text-center px-6 max-w-4xl mx-auto py-24">

        <!-- Hero seal — ID required for scroll migration animation -->
        <div id="hero-seal" class="w-24 h-24 rounded-full overflow-hidden mx-auto mb-8 ring-2 ring-white/20">
          <Image
            src={polisMain}
            alt=""
            width={240}
            class="w-full h-full object-cover object-center"
            loading="eager"
          />
        </div>
        <h1 class="font-heading text-white leading-tight mb-5 hero-wordmark">
          <span class="block text-[58px] md:text-[82px] lg:text-[106px]">POLIS</span>
        </h1>

        <p class="font-heading text-white/90 text-xl md:text-2xl max-w-2xl mx-auto leading-relaxed mb-8">
          {home.hero.tagline}
        </p>

        <div class="flex flex-col items-center gap-3">
          <a
            href={site.applyUrl}
            target="_blank"
            rel="noopener noreferrer"
            data-magnetic
            class="apply-hero-btn min-h-[44px] inline-flex items-center justify-center font-heading font-semibold text-base px-7 py-3 rounded-sm focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-2 focus:ring-offset-dark-blue"
          >
            Apply Now
            <span class="btn-arrow" aria-hidden="true">→</span>
            <span class="sr-only">(opens in new tab)</span>
          </a>
          <p class="font-heading text-white/85 text-sm tracking-wide">Become a Founding Member</p>
        </div>

      </div>

      <!-- Scroll cue chevron — fades out on scroll, no animation under prefers-reduced-motion -->
      <div id="scroll-cue" aria-hidden="true"
           class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
             style="color: var(--color-gold)">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </div>

    </section>


    <!-- ============================================================
         SECTION SUB-NAV — sticky below header, lg+ only
         ============================================================ -->
    <nav
      aria-label="Page sections"
      class="hidden lg:block sticky top-14 md:top-16 z-40 bg-white border-b border-gray/60"
    >
      <div class="max-w-7xl mx-auto px-6 flex gap-8 py-3">
        <a href="#who-we-are" class="section-nav-link font-heading text-sm whitespace-nowrap">Who We Are</a>
        <a href="#why-polis"  class="section-nav-link font-heading text-sm whitespace-nowrap">Why POLIS</a>
        <a href="#mission"    class="section-nav-link font-heading text-sm whitespace-nowrap">Mission</a>
      </div>
    </nav>


    <!-- ============================================================
         WHO WE ARE
         ============================================================ -->
    <section id="who-we-are" data-section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-6xl mx-auto">

        <div class="section-divider" aria-hidden="true"></div>
        <h2 class="font-heading text-dark-blue text-4xl md:text-5xl mb-12 text-center">
          Who We Are
        </h2>

        <div class="flex flex-col md:flex-row items-start gap-12">

          <!-- Text -->
          <div class="flex-1 font-heading text-dark-blue text-lg leading-relaxed space-y-6">
            <div set:html={toHtmlLedeFirstPara(home.whoWeAre.body)} />
            <blockquote class="pull-quote">
              <p>{home.whoWeAre.pullQuote}</p>
            </blockquote>
            <div set:html={toHtmlAfterFirstPara(home.whoWeAre.body)} />
          </div>

          <!-- Photo + CTA -->
          <div class="w-full md:w-80 lg:w-96 shrink-0 flex flex-col gap-4">
            <Image
              src={landingImage}
              alt="The U.S. Capitol building"
              width={800}
              height={533}
              class="w-full h-auto rounded-sm object-cover"
              loading="lazy"
            />
            <a
              href={site.execBoardUrl}
              data-magnetic
              class="self-center min-h-[44px] inline-flex items-center justify-center border border-dark-blue text-dark-blue font-heading font-semibold text-base px-7 py-3 rounded-sm hover:bg-dark-blue/10 focus:outline-none focus:ring-2 focus:ring-dark-blue focus:ring-offset-2 transition"
            >
              Meet the Founding Executive Board
            </a>
          </div>

        </div>

      </div>
    </section>


    <!-- ============================================================
         WHY POLIS?
         ============================================================ -->
    <section id="why-polis" data-section class="bg-light-blue py-20 md:py-28 px-6">
      <div class="max-w-6xl mx-auto">

        <div class="section-divider" aria-hidden="true"></div>
        <h2 class="font-heading text-dark-blue text-4xl md:text-5xl mb-12 text-center">
          Why POLIS?
        </h2>

        <div class="flex flex-col md:flex-row-reverse items-start gap-12">

          <!-- Text -->
          <div class="flex-1 font-heading text-dark-blue text-lg leading-relaxed space-y-6">
            <div set:html={toHtmlLedeFirstPara(home.whyPolis.body)} />
            <blockquote class="pull-quote">
              <p>{home.whyPolis.pullQuote}</p>
            </blockquote>
            <div set:html={toHtmlAfterFirstPara(home.whyPolis.body)} />
          </div>

          <!-- Photo + CTA -->
          <div class="w-full md:w-80 lg:w-96 shrink-0 flex flex-col gap-4">
            <Image
              src={ufImage}
              alt="University of Florida campus"
              width={800}
              height={533}
              class="w-full h-auto rounded-sm object-cover"
              loading="lazy"
            />
            <a
              href={site.instagram}
              target="_blank"
              rel="noopener noreferrer"
              data-magnetic
              class="self-center min-h-[44px] inline-flex items-center justify-center border border-dark-blue text-dark-blue font-heading font-semibold text-base px-7 py-3 rounded-sm hover:bg-dark-blue/10 focus:outline-none focus:ring-2 focus:ring-dark-blue focus:ring-offset-2 transition"
            >
              Follow Us on Instagram
              <span class="sr-only">(opens in new tab)</span>
            </a>
          </div>

        </div>

      </div>
    </section>


    <!-- ============================================================
         MISSION
         ============================================================ -->
    <section id="mission" data-section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-6xl mx-auto mb-16">

        <div class="section-divider" aria-hidden="true"></div>
        <h2 class="font-heading text-dark-blue text-4xl md:text-5xl mb-10 text-center">
          Mission
        </h2>

        <div class="flex flex-col md:flex-row items-start gap-12">

          <!-- Text -->
          <div class="flex-1 font-heading text-dark-blue text-lg leading-relaxed space-y-6">
            <div set:html={toHtmlLedeFirstPara(home.mission.body)} />
            <blockquote class="pull-quote">
              <p>{home.mission.pullQuote}</p>
            </blockquote>
            <div set:html={toHtmlAfterFirstPara(home.mission.body)} />
          </div>

          <!-- Photo + Philanthropy CTA -->
          <div class="w-full md:w-80 lg:w-96 shrink-0 flex flex-col gap-4">
            <Image
              src={senatePainting}
              alt="Senate chamber painting"
              width={800}
              height={533}
              class="w-full h-auto rounded-sm object-cover"
              loading="lazy"
            />
            <a
              href="/philanthropy"
              data-magnetic
              class="self-center min-h-[44px] inline-flex items-center justify-center border border-dark-blue text-dark-blue font-heading font-semibold text-base px-7 py-3 rounded-sm hover:bg-dark-blue/10 focus:outline-none focus:ring-2 focus:ring-dark-blue focus:ring-offset-2 transition"
            >
              Explore Our Philanthropy
            </a>
          </div>

        </div>

      </div>

      <div class="max-w-4xl mx-auto">
        <h3 class="font-heading text-dark-blue text-2xl md:text-3xl mb-8 text-center">
          Our Mission Is Centered on Three Key Goals
        </h3>
      </div>

      <!-- Three goal cards — wider container, always-visible static grid -->
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-icon-grid>

          {home.mission.goals.map((goal: any, i: number) => (
            <div class="flip-card-wrapper fade-up" style={`transition-delay: ${i * 80}ms`}>
            <button
              type="button"
              class="flip-card"
              aria-pressed="false"
              aria-label={`${goal.title}, activate to read more`}
            >
              <div class="flip-inner">
                <div class="flip-front">
                  <div class="text-gold" aria-hidden="true" data-draw-icon set:html={goalIcons[i]} />
                  <h4 class="font-heading text-white text-xl leading-snug">
                    {goal.title}
                  </h4>
                  <div class="flip-indicator" aria-hidden="true">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M23 4v6h-6"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
                    </svg>
                  </div>
                </div>
                <div class="flip-back" aria-hidden="true" inert>
                  <div class="font-heading text-white/85 text-base leading-relaxed" set:html={toHtml(goal.body)} />
                  <div class="mt-auto flex items-center justify-between">
                    <div class="text-gold" aria-hidden="true" set:html={goalIcons[i].replace('width="32" height="32"', 'width="20" height="20"')} />
                    <div class="flip-indicator" style="margin-top:0" aria-hidden="true">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M1 4v6h6"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                      </svg>
                    </div>
                  </div>
                </div>
              </div>
            </button>
            </div>
          ))}

        </div>
      </div>

    </section>


    <!-- ============================================================
         WHERE WE WORK — logo marquee + founding pull quote
         ============================================================ -->
    <section class="bg-light-blue py-20 md:py-28 px-6">

      <div class="max-w-6xl mx-auto">
        <div class="section-divider" aria-hidden="true"></div>
        <h2 class="font-heading text-dark-blue text-4xl md:text-5xl mb-3 text-center">
          Where We Work
        </h2>
        <p class="font-heading text-dark-blue/60 text-base text-center mb-12">
          Click to see our network
        </p>
      </div>

      <!-- Marquee -->
      <div
        class="marquee-container relative overflow-hidden"
        role="region"
        aria-label="Where we work, scrolling list of internship placements"
      >
        <!-- Pause / Play toggle — hidden under prefers-reduced-motion via CSS -->
        <button
          id="marquee-toggle"
          type="button"
          aria-label="Pause network logos"
          class="absolute top-2 right-4 z-10 min-w-[36px] min-h-[36px] flex items-center justify-center bg-white/80 border border-dark-blue/20 rounded-sm text-dark-blue hover:bg-white hover:border-gold transition-colors focus:outline-none focus:ring-2 focus:ring-gold focus:ring-offset-1"
        >
          <svg id="marquee-pause-icon" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <rect x="5"  y="3" width="4" height="18" rx="1"/>
            <rect x="15" y="3" width="4" height="18" rx="1"/>
          </svg>
          <svg id="marquee-play-icon" aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" class="hidden">
            <polygon points="5,3 19,12 5,21"/>
          </svg>
        </button>

        <!-- Scrolling track — two identical lists for seamless loop -->
        <div class="marquee-track flex items-center gap-16 w-max py-6">

          <!-- First copy (keyboard-accessible) -->
          <div class="marquee-list flex items-center gap-16">
            {allLogos.map((logo) => (
              <a
                href="/network"
                class="marquee-logo shrink-0"
                aria-label={`${logo.title} — view our network`}
              >
                <div class="bg-white rounded-sm px-4 py-3 flex items-center justify-center h-[90px] min-w-[110px]">
                  <img
                    src={logo.src}
                    alt={logo.alt}
                    class="max-h-[64px] w-auto max-w-[130px] object-contain"
                    loading="lazy"
                  />
                </div>
              </a>
            ))}
          </div>

          <!-- Duplicate copy — aria-hidden + tabindex=-1 to avoid double focus -->
          <div class="marquee-list flex items-center gap-16" aria-hidden="true">
            {allLogos.map((logo) => (
              <a
                href="/network"
                class="marquee-logo shrink-0"
                tabindex="-1"
                aria-hidden="true"
              >
                <div class="bg-white rounded-sm px-4 py-3 flex items-center justify-center h-[90px] min-w-[110px]">
                  <img
                    src={logo.src}
                    alt=""
                    class="max-h-[64px] w-auto max-w-[130px] object-contain"
                    loading="lazy"
                  />
                </div>
              </a>
            ))}
          </div>

        </div>
      </div>

      <!-- Pull quote (moved from Mission section) -->
      <div class="max-w-4xl mx-auto mt-12">
        <blockquote class="pull-quote">
          <p>{home.mission.closingQuote}</p>
        </blockquote>
      </div>

      <div class="flex justify-center mt-10">
        <a
          href={site.applyUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-magnetic
          class="min-h-[44px] inline-flex items-center justify-center bg-gold text-dark-blue font-heading font-semibold text-base px-7 py-3 rounded-sm hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-dark-blue focus:ring-offset-2 transition"
        >
          Apply Now
          <span class="sr-only">(opens in new tab)</span>
        </a>
      </div>

    </section>


    <!-- MLK quote easter egg overlay — triggered by triple-clicking the hero seal -->
    <div
      id="quote-overlay"
      role="dialog"
      aria-label="Quote"
      aria-hidden="true"
      class="fixed inset-0 z-50 flex items-center justify-center p-6"
    >
      <div class="absolute inset-0 bg-dark-blue/75" aria-hidden="true"></div>
      <div
        id="quote-card"
        tabindex="-1"
        class="relative z-10 max-w-xl w-full bg-dark-blue border-t-4 border-gold rounded-sm p-8 md:p-10 shadow-2xl"
      >
        <blockquote class="font-heading italic text-white text-2xl leading-relaxed mb-5">
          "Life's most persistent and urgent question is, 'What are you doing for others?'"
        </blockquote>
        <p class="font-heading text-white/70 text-base not-italic">
          — Martin Luther King Jr.
        </p>
      </div>
    </div>

  </main>
</Layout>

<script>
  // ── Easter egg state — module-level so it persists across navigations ──
  let _eggAbort: AbortController | null = null;
  let _eggCount = 0;
  let _lastClick = 0;

  function initSealEasterEgg() {
    _eggAbort?.abort();
    _eggAbort = null;

    const seal    = document.getElementById('hero-seal')     as HTMLElement | null;
    const overlay = document.getElementById('quote-overlay') as HTMLElement | null;
    const card    = document.getElementById('quote-card')    as HTMLElement | null;
    if (!seal || !overlay || !card) return;

    const noMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    _eggAbort = new AbortController();
    const { signal } = _eggAbort;

    // Track pointer-down position + time to exclude drags and long-presses
    let _downX = 0, _downY = 0, _downTime = 0;
    seal.addEventListener('pointerdown', (e) => {
      _downX    = (e as PointerEvent).clientX;
      _downY    = (e as PointerEvent).clientY;
      _downTime = Date.now();
    }, { signal });

    seal.addEventListener('click', (e) => {
      const moved = Math.abs((e as MouseEvent).clientX - _downX) > 8
                 || Math.abs((e as MouseEvent).clientY - _downY) > 8;
      const held  = Date.now() - _downTime > 500;
      if (moved || held) { _eggCount = 0; _lastClick = 0; return; }

      const now = Date.now();
      if (now - _lastClick > 1500) _eggCount = 0;  // gap too long — reset
      _lastClick = now;
      _eggCount++;

      if (_eggCount >= 3) {
        _eggCount  = 0;
        _lastClick = 0;
        showQuote();
      }
    }, { signal });

    function showQuote() {
      if (overlay.classList.contains('is-visible')) return;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-visible');
      card.focus();
    }

    function hideQuote() {
      overlay.classList.remove('is-visible');
      setTimeout(
        () => overlay.setAttribute('aria-hidden', 'true'),
        noMotion ? 0 : 400
      );
      seal.focus();
    }

    // Dismiss: click anywhere on the overlay (backdrop + card)
    overlay.addEventListener('click', hideQuote, { signal });

    // Dismiss: Escape key
    document.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && overlay.classList.contains('is-visible')) {
        hideQuote();
      }
    }, { signal });
  }

  document.addEventListener('astro:page-load', () => {
    initSealEasterEgg();

    // ----------------------------------------------------------------
    // Marquee pause/play toggle
    // ----------------------------------------------------------------
    const marqueeToggle = document.getElementById('marquee-toggle')    as HTMLButtonElement | null;
    const marqueeTrack  = document.querySelector<HTMLElement>('.marquee-track');
    const pauseIcon     = document.getElementById('marquee-pause-icon') as SVGElement | null;
    const playIcon      = document.getElementById('marquee-play-icon')  as SVGElement | null;

    if (marqueeToggle && marqueeTrack && pauseIcon && playIcon) {
      marqueeToggle.addEventListener('click', () => {
        const isPaused = marqueeTrack.classList.toggle('is-paused');
        marqueeToggle.setAttribute('aria-label', isPaused ? 'Play network logos' : 'Pause network logos');
        pauseIcon.classList.toggle('hidden', isPaused);
        playIcon.classList.toggle('hidden', !isPaused);
      });
    }

    // Guard: only run on pages that have a section sub-nav
    const sections = [...document.querySelectorAll('[data-section]')];
    const navLinks = [...document.querySelectorAll('.section-nav-link')];
    if (!sections.length) return;

    // ----------------------------------------------------------------
    // Section sub-nav: track visible sections, highlight the topmost
    // ----------------------------------------------------------------
    const visible = new Set<Element>();

    function updateNav() {
      const tops = [...visible].map((el) => ({
        el,
        top: (el as HTMLElement).getBoundingClientRect().top,
      }));
      const inView = tops.filter(({ top }) => top >= 0);
      const candidate = inView.length
        ? inView.reduce((a, b) => (a.top <= b.top ? a : b))
        : tops.length
        ? tops.reduce((a, b) => (a.top >= b.top ? a : b))
        : null;

      navLinks.forEach((l) => l.classList.remove('active'));
      if (candidate) {
        document
          .querySelector(`.section-nav-link[href="#${(candidate.el as HTMLElement).id}"]`)
          ?.classList.add('active');
      }
    }

    const sectionObs = new IntersectionObserver(
      (entries) => {
        entries.forEach(({ target, isIntersecting }) => {
          isIntersecting ? visible.add(target) : visible.delete(target);
        });
        updateNav();
      },
      { rootMargin: '0px 0px -20% 0px', threshold: 0 }
    );
    sections.forEach((s) => sectionObs.observe(s));

    // ----------------------------------------------------------------
    // Hero cursor-following spotlight (Effect 4)
    // ----------------------------------------------------------------
    const hero = document.querySelector<HTMLElement>('.hero-spotlight');
    if (hero && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let spotRaf: number;
      hero.addEventListener('mousemove', (e) => {
        cancelAnimationFrame(spotRaf);
        spotRaf = requestAnimationFrame(() => {
          const r = hero.getBoundingClientRect();
          hero.style.setProperty('--cursor-x', `${((e as MouseEvent).clientX - r.left) / r.width * 100}%`);
          hero.style.setProperty('--cursor-y', `${((e as MouseEvent).clientY - r.top) / r.height * 100}%`);
        });
      });
      hero.addEventListener('mouseleave', () => {
        cancelAnimationFrame(spotRaf);
        hero.style.setProperty('--cursor-x', '50%');
        hero.style.setProperty('--cursor-y', '50%');
      });
    }

    // ----------------------------------------------------------------
    // SVG icon self-draw (Effect 8)
    // Only <path> elements animate; other shapes appear instantly.
    // Draws after card fade-up completes (300ms base + 80ms stagger).
    // ----------------------------------------------------------------
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('[data-icon-grid]').forEach((grid) => {
        const obs = new IntersectionObserver(([entry]) => {
          if (!entry.isIntersecting) return;
          obs.unobserve(entry.target);
          grid.querySelectorAll<HTMLElement>('[data-draw-icon]').forEach((iconEl, i) => {
            const paths = iconEl.querySelectorAll<SVGGeometryElement>('path');
            paths.forEach((p) => {
              const len = p.getTotalLength();
              p.style.strokeDasharray = String(len);
              p.style.strokeDashoffset = String(len);
            });
            setTimeout(() => {
              paths.forEach((p) => { p.style.strokeDashoffset = '0'; });
            }, 300 + i * 80);
          });
        }, { threshold: 0.2 });
        obs.observe(grid);
      });
    }
  });
</script>
