---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import polisPlaceholder from '../assets/polis_placeholder.jpg';
import site from '../data/site.json';
import { toHtml } from '../utils/markdown';

// To edit recruitment copy, FAQs, or timeline, edit src/data/join.json — not this file.
import joinData from '../data/join.json';
---

<Layout
  title="Apply to POLIS UF | Founding Class Recruitment"
  description="Apply to join POLIS UF (UF POLIS) at UF. Pi Lambda Sigma's Founding Class for pre-law, public service, policy, and civic leadership students."
>
  <main id="main-content">

    <!-- Page header -->
    <section class="bg-dark-blue py-20 md:py-28 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-heading text-gold text-sm uppercase tracking-widest mb-4">Founding Class</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl leading-tight mb-6">
          Join POLIS
        </h1>
        <p class="font-heading text-white/80 text-xl max-w-2xl mx-auto leading-relaxed mb-10">
          Applications for our Founding Class are coming soon.
        </p>
        <a
          href={site.applyUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-magnetic
          class="inline-block bg-gold text-dark-blue font-heading font-semibold text-lg px-8 py-4 rounded-sm hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-dark-blue transition"
        >
          Apply Now
          <span class="sr-only">(opens in new tab)</span>
        </a>
      </div>
    </section>


    <!-- Section sub-nav — sticky below header, lg+ only -->
    <nav
      aria-label="Page sections"
      class="hidden lg:block sticky top-14 md:top-16 z-40 bg-white border-b border-gray/60"
    >
      <div class="max-w-7xl mx-auto px-6 flex gap-8 py-3">
        <a href="#process"   class="section-nav-link font-heading text-sm whitespace-nowrap">Our Process</a>
        <a href="#timeline"  class="section-nav-link font-heading text-sm whitespace-nowrap">Timeline</a>
        <a href="#questions" class="section-nav-link font-heading text-sm whitespace-nowrap">Questions</a>
        <a href="#faq"       class="section-nav-link font-heading text-sm whitespace-nowrap">FAQ</a>
      </div>
    </nav>


    <!-- Recruitment process -->
    <section id="process" data-section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-6xl mx-auto">

        <h2 class="font-heading text-dark-blue text-3xl md:text-4xl text-center mb-14 fade-up">
          Our Recruitment Process
        </h2>

        <div class="flex flex-col md:flex-row items-start gap-12">

          <div class="flex-1 font-heading text-dark-blue text-lg leading-relaxed space-y-6 fade-up">
            <div class="lede" set:html={toHtml(joinData.process.body)} />
            <blockquote class="pull-quote">
              <p>{joinData.processPullQuote}</p>
            </blockquote>
          </div>

          <div class="w-full md:w-80 lg:w-96 shrink-0 fade-up" style="transition-delay: 150ms">
            <Image
              src={polisPlaceholder}
              alt="Placeholder photo — POLIS UF recruitment (to be replaced)"
              width={400}
              height={400}
              class="w-full h-auto rounded-sm object-cover"
              loading="lazy"
            />
          </div>

        </div>
      </div>
    </section>


    <!-- Recruitment timeline -->
    <section id="timeline" data-section class="bg-gray/20 py-20 md:py-28 px-6">
      <div class="max-w-5xl mx-auto">

        <h2 class="font-heading text-dark-blue text-3xl md:text-4xl text-center mb-4 fade-up">
          Recruitment Timeline
        </h2>
        <p class="font-heading text-dark-blue/60 text-center text-base mb-16 fade-up">
          Timeline coming soon. Dates will be updated before each recruitment cycle.
        </p>

        <!-- Horizontal step timeline -->
        <div class="relative fade-up">
          <div class="hidden md:block absolute top-5 left-0 right-0 h-px bg-gold" aria-hidden="true"></div>

          <ol class="grid grid-cols-1 md:grid-cols-4 gap-8 list-none p-0 m-0" role="list">
            {joinData.timeline.map((step: any, i: number) => (
              <li class="flex flex-col items-center text-center gap-3" style={`transition-delay: ${i * 100}ms`}>
                <div class="w-10 h-10 rounded-full bg-gold border-4 border-white shadow flex items-center justify-center shrink-0 z-10">
                  <span class="font-heading text-dark-blue text-sm font-semibold">{i + 1}</span>
                </div>
                <p class="font-heading text-dark-blue text-base leading-snug">{step.label}</p>
                <p class="font-heading text-dark-blue/50 text-sm">{step.date}</p>
              </li>
            ))}
          </ol>
        </div>

      </div>
    </section>


    <!-- Questions: VP of Recruitment contact -->
    <section id="questions" data-section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-4xl mx-auto">

        <h2 class="font-heading text-dark-blue text-3xl md:text-4xl text-center mb-14 fade-up">
          Questions About Recruitment?
        </h2>

        <div class="fade-up flex flex-col md:flex-row items-center gap-10 border border-gray rounded-sm p-8 shadow-sm">

          <!-- Circular headshot placeholder -->
          <div class="w-40 h-40 rounded-full overflow-hidden border-4 border-gold shrink-0">
            <Image
              src={polisPlaceholder}
              alt="Abagail Price — VP of Recruitment"
              width={160}
              height={160}
              class="w-full h-full object-cover opacity-60"
              loading="lazy"
            />
          </div>

          <!-- Text -->
          <div class="flex flex-col gap-2 text-center md:text-left">
            <p class="font-heading text-gold text-sm uppercase tracking-widest">VP of Recruitment</p>
            <h3 class="font-heading text-dark-blue text-2xl">Abagail Price</h3>
            <p class="font-heading text-dark-blue/70 text-base leading-relaxed mt-2">
              Abagail Price serves as POLIS's VP of Recruitment and is the primary point of
              contact for all recruitment and application questions. If you have questions about
              joining, the recruitment process, or what to expect, reach out directly.
            </p>
            <div class="mt-3 flex flex-wrap items-center gap-3 justify-center md:justify-start">
              <a
                href={`mailto:${site.email}`}
                class="inline-flex items-center gap-2 font-heading text-dark-blue text-base
                       border border-gray/60 px-5 py-2.5 rounded-sm hover:border-gold
                       hover:shadow-sm transition-all duration-200"
                aria-label={`Email POLIS UF at ${site.email}`}
              >
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="M2 7l10 7 10-7"/>
                </svg>
                {site.email}
              </a>
              <a
                href="https://www.linkedin.com/in/abagail-price-b8a52229a/"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 font-heading text-dark-blue text-base
                       border border-gray/60 px-5 py-2.5 rounded-sm hover:border-gold
                       hover:shadow-sm transition-all duration-200"
                aria-label="Abagail Price on LinkedIn (opens in new tab)"
              >
                <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
                <span class="sr-only">(opens in new tab)</span>
              </a>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- FAQ section -->
    <section id="faq" data-section class="bg-dark-blue py-20 md:py-28 px-6">
      <div class="max-w-3xl mx-auto">

        <h2 class="font-heading text-white text-3xl md:text-4xl text-center mb-14 fade-up">
          Frequently Asked Questions
        </h2>

        <div class="divide-y divide-white/20 fade-up">
          {joinData.faqs.map((faq: any) => (
            <details class="group py-1">
              <summary class="font-heading text-white text-lg py-4 cursor-pointer list-none flex justify-between items-center gap-4 hover:text-gold transition-colors">
                {faq.q}
                <svg
                  aria-hidden="true"
                  class="w-4 h-4 shrink-0 opacity-60 transition-transform duration-300 group-open:rotate-180"
                  viewBox="0 0 16 16"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <polyline points="3 6 8 11 13 6" />
                </svg>
              </summary>
              <div class="grid grid-rows-[0fr] group-open:grid-rows-[1fr] transition-all duration-300 ease-in-out">
                <div class="overflow-hidden">
                  <div class="font-heading text-white/75 text-base leading-relaxed pb-5 pt-1"
                    set:html={toHtml(faq.a)} />
                </div>
              </div>
            </details>
          ))}
        </div>

      </div>
    </section>


    <!-- Bottom CTA -->
    <section class="bg-white py-20 px-6">
      <div class="max-w-2xl mx-auto text-center fade-up">
        <h2 class="font-heading text-dark-blue text-3xl md:text-4xl mb-6">
          Ready to Apply?
        </h2>
        <p class="font-heading text-dark-blue/70 text-lg leading-relaxed mb-10">
          Join POLIS's Founding Class and help build a community of future public service leaders
          at the University of Florida.
        </p>
        <a
          href={site.applyUrl}
          target="_blank"
          rel="noopener noreferrer"
          data-magnetic
          class="inline-block bg-gold text-dark-blue font-heading font-semibold text-lg px-10 py-4 rounded-sm hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-dark-blue focus:ring-offset-2 transition"
        >
          Apply Now
          <span class="sr-only">(opens in new tab)</span>
        </a>
      </div>
    </section>

  </main>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const sections = [...document.querySelectorAll('[data-section]')];
    const navLinks = [...document.querySelectorAll('.section-nav-link')];
    if (!sections.length) return;

    const visible = new Set<Element>();

    function updateNav() {
      const tops = [...visible].map((el) => ({
        el,
        top: (el as HTMLElement).getBoundingClientRect().top,
      }));
      const inView = tops.filter(({ top }) => top >= 0);
      const candidate = inView.length
        ? inView.reduce((a, b) => (a.top <= b.top ? a : b))
        : tops.length
        ? tops.reduce((a, b) => (a.top >= b.top ? a : b))
        : null;

      navLinks.forEach((l) => l.classList.remove('active'));
      if (candidate) {
        document
          .querySelector(`.section-nav-link[href="#${(candidate.el as HTMLElement).id}"]`)
          ?.classList.add('active');
      }
    }

    const sectionObs = new IntersectionObserver(
      (entries) => {
        entries.forEach(({ target, isIntersecting }) => {
          isIntersecting ? visible.add(target) : visible.delete(target);
        });
        updateNav();
      },
      { rootMargin: '0px 0px -20% 0px', threshold: 0 }
    );
    sections.forEach((s) => sectionObs.observe(s));
  });
</script>
