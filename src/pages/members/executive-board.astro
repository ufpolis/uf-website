---
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import polisPlaceholder from '../../assets/polis_placeholder.jpg';

// To add or remove board members, edit src/data/executiveBoard.json — not this file.
import boardData from '../../data/executiveBoard.json';
const members = (boardData as any[]).filter((m) => !m._instructions);

// Load all headshots from src/assets/headshots/ and build a filename-stem → ImageMetadata map.
// To add a new headshot: drop the file in src/assets/headshots/ and set "headshot" in
// executiveBoard.json to the filename without extension (e.g. "first-last").
const headshotModules = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/headshots/*.{jpg,jpeg,JPG,JPEG,png,PNG,webp}',
  { eager: true }
);
const headshotMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(headshotModules)) {
  const stem = path.split('/').pop()?.replace(/\.[^.]+$/, '') ?? '';
  headshotMap[stem] = mod.default;
}
---

<Layout
  title="Executive Board | POLIS UF"
  description="Meet the founding executive board of POLIS UF (UF POLIS), a Pi Lambda Sigma chapter at the University of Florida for public service and pre-law."
>
  <main id="main-content">

    <!-- Page header -->
    <section class="bg-dark-blue py-20 md:py-28 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-heading text-gold text-sm uppercase tracking-widest mb-4">Leadership</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl leading-tight mb-6">
          Executive Board
        </h1>
        <p class="font-heading text-white/80 text-xl max-w-2xl mx-auto leading-relaxed">
          Meet the founding leaders of POLIS. This team is building the chapter's culture,
          programming, and professional network from the ground up.
        </p>
      </div>
    </section>


    <!-- Member grid -->
    <section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-7xl mx-auto">

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
          {members.map((member: any, i: number) => (
            <article
              class="fade-up bg-white border border-gray rounded-sm overflow-hidden
                     hover:-translate-y-1 hover:shadow-xl hover:border-gold transition-all duration-300 flex flex-col"
              style={`transition-delay: ${i * 60}ms`}
            >
              <!-- Headshot -->
              <div class="w-full aspect-square overflow-hidden bg-gray/20 shrink-0">
                {member.headshot && headshotMap[member.headshot]
                  ? (
                    <Image
                      src={headshotMap[member.headshot]}
                      alt={`${member.name} headshot`}
                      width={300}
                      height={300}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <Image
                      src={polisPlaceholder}
                      alt=""
                      width={300}
                      height={300}
                      class="w-full h-full object-cover opacity-60"
                      loading="lazy"
                    />
                  )
                }
              </div>

              <!-- Member details: text left, LinkedIn button right -->
              <div class="border-t-4 border-gold p-4 flex items-start justify-between gap-3">
                <!-- Text group -->
                <div class="flex flex-col gap-0.5 min-w-0">
                  <h3 class="font-heading text-dark-blue text-lg leading-snug">
                    {member.name}
                  </h3>
                  <p class="font-heading text-gold text-sm leading-snug">
                    {member.position}
                  </p>
                  {member.major && member.major !== '[Major, Year]' && (
                    <p class="font-heading text-dark-blue/50 text-xs mt-0.5">{member.major}</p>
                  )}
                </div>

                <!-- LinkedIn icon — active when set, dimmed placeholder when null -->
                <div class="shrink-0">
                  {member.linkedin ? (
                    <a
                      href={member.linkedin}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="flex items-center justify-center w-8 h-8 rounded-sm border border-gray/60
                             text-dark-blue hover:border-gold hover:text-gold transition-all duration-200"
                      aria-label={`${member.name} on LinkedIn (opens in new tab)`}
                    >
                      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                      <span class="sr-only">{member.name} on LinkedIn (opens in new tab)</span>
                    </a>
                  ) : (
                    <span
                      class="flex items-center justify-center w-8 h-8 rounded-sm border border-gray/20
                             text-dark-blue/25 cursor-default"
                      aria-label={`${member.name} LinkedIn not yet added`}
                    >
                      <svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                    </span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

      </div>
    </section>

  </main>
</Layout>
