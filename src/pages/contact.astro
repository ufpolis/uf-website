---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout
  title="Contact POLIS UF"
  description="Contact POLIS UF (UF POLIS), the Pi Lambda Sigma founding chapter at the University of Florida. Reach us via Instagram, LinkedIn, or email."
>
  <main id="main-content">

    <!-- Page header -->
    <section class="bg-dark-blue py-20 md:py-28 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="font-heading text-gold text-sm uppercase tracking-widest mb-4">Get in Touch</p>
        <h1 class="font-heading text-white text-5xl md:text-6xl leading-tight mb-6">
          Contact
        </h1>
        <p class="font-heading text-white/80 text-xl max-w-2xl mx-auto leading-relaxed">
          We would love to hear from you. Reach us through any of the channels below.
        </p>
      </div>
    </section>


    <!-- Channel cards -->
    <section class="bg-white py-20 md:py-28 px-6">
      <div class="max-w-3xl mx-auto flex flex-col gap-6">

        <!-- Instagram -->
        <a
          href={site.instagram}
          target="_blank"
          rel="noopener noreferrer"
          class="fade-up group flex items-center gap-6 bg-dark-blue rounded-sm px-8 py-7
                 hover:brightness-110 transition-all duration-300 shadow-md"
          aria-label={`Follow POLIS UF on Instagram — ${site.instagramHandle} (opens in new tab)`}
        >
          <!-- Instagram icon -->
          <div class="shrink-0 text-gold">
            <svg aria-hidden="true" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-heading text-gold text-xs uppercase tracking-widest mb-1">Instagram</p>
            <p class="font-heading text-white text-xl md:text-2xl">Follow us on Instagram</p>
            <p class="font-heading text-white/60 text-sm mt-1">{site.instagramHandle}</p>
          </div>
          <div class="shrink-0 text-white/40 group-hover:text-gold transition-colors duration-200">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
          <span class="sr-only">(opens in new tab)</span>
        </a>

        <!-- LinkedIn -->
        <a
          href={site.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="fade-up group flex items-center gap-6 bg-dark-blue rounded-sm px-8 py-7
                 hover:brightness-110 transition-all duration-300 shadow-md"
          style="transition-delay: 100ms"
          aria-label="Connect with POLIS UF on LinkedIn (opens in new tab)"
        >
          <!-- LinkedIn icon -->
          <div class="shrink-0 text-gold">
            <svg aria-hidden="true" width="36" height="36" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-heading text-gold text-xs uppercase tracking-widest mb-1">LinkedIn</p>
            <p class="font-heading text-white text-xl md:text-2xl">Connect with us on LinkedIn</p>
            <p class="font-heading text-white/60 text-sm mt-1">University of Florida POLIS</p>
          </div>
          <div class="shrink-0 text-white/40 group-hover:text-gold transition-colors duration-200">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
          <span class="sr-only">(opens in new tab)</span>
        </a>

        <!-- Email -->
        <a
          href={`mailto:${site.email}`}
          class="fade-up group flex items-center gap-6 bg-dark-blue rounded-sm px-8 py-7
                 hover:brightness-110 transition-all duration-300 shadow-md"
          style="transition-delay: 200ms"
          aria-label={`Email POLIS UF at ${site.email}`}
        >
          <!-- Email icon -->
          <div class="shrink-0 text-gold">
            <svg aria-hidden="true" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="M2 7l10 7 10-7"/>
            </svg>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-heading text-gold text-xs uppercase tracking-widest mb-1">Email</p>
            <p class="font-heading text-white text-xl md:text-2xl">Email us</p>
            <p class="font-heading text-white/60 text-sm mt-1">{site.email}</p>
          </div>
          <div class="shrink-0 text-white/40 group-hover:text-gold transition-colors duration-200">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </div>
        </a>

      </div>
    </section>

  </main>
</Layout>
